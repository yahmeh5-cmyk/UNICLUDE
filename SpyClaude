-- Serializar argumentos de forma segura
local function serializeArgs(args)
    local result = {}
    for i, v in ipairs(args) do
        local success, serialized = pcall(function()
            if typeof(v) == "Instance" then
                return string.format("[%s] %s", v.ClassName, v:GetFullName())
            elseif typeof(v) == "table" then
                return HttpService:JSONEncode(v)
            else
                return tostring(v)
            end
        end)
        table.insert(result, success and serialized or "[Error serializing]")
    end
    return table.concat(result, ", ")
end

-- Hook de Remotes otimizado
local function hookRemotes()
    local function hookRemote(remote)
        if SpyTool.Data.connections[remote] then return end
        
        local originalNamecall
        originalNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            if self == remote and (method == "FireServer" or method == "InvokeServer") then
                local logEntry = {
                    type = remote.ClassName,
                    name = remote:GetFullName(),
                    method = method,
                    args = args,
                    time = os.date("%H:%M:%S")
                }
                
                table.insert(SpyTool.Data.remotes, logEntry)
                
                -- Limitar logs para performance
                if #SpyTool.Data.remotes > Config.maxLogs then
                    table.remove(SpyTool.Data.remotes, 1)
                end
            end
            
            return originalNamecall(self, ...)
        end)
        
        SpyTool.Data.connections[remote] = true
    end
    
    -- Hook remotes existentes
    for _, descendant in ipairs(game:GetDescendants()) do
        if descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction") then
            hookRemote(descendant)
        end
    end
    
    -- Hook novos remotes
    game.DescendantAdded:Connect(function(descendant)
        if descendant:IsA("RemoteEvent") or descendant:IsA("RemoteFunction") then
            task.wait(0.1)
            hookRemote(descendant)
        end
    end)
end

-- Capturar Workspace
local function captureWorkspace()
    local function scanInstance(instance, depth)
        if depth > 5 then return "..." end
        
        local info = {
            name = instance.Name,
            class = instance.ClassName,
            children = {}
        }
        
        for _, child in ipairs(instance:GetChildren()) do
            if #info.children < 10 then
                table.insert(info.children, scanInstance(child, depth + 1))
