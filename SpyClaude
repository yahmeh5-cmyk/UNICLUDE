-- Exportar dados
local function exportData()
    local exportText = "=== ROBLOX SPY TOOL EXPORT ===\n\n"
    
    exportText = exportText .. "🌐 GAME INFO:\n"
    exportText = exportText .. "Name: " .. game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name .. "\n"
    exportText = exportText .. "PlaceId: " .. tostring(game.PlaceId) .. "\n"
    exportText = exportText .. "JobId: " .. game.JobId .. "\n\n"
    
    exportText = exportText .. "📡 REMOTE EVENTS (" .. #SpyTool.Data.remotes .. " captured):\n"
    for i, remote in ipairs(SpyTool.Data.remotes) do
        exportText = exportText .. string.format(
            "[%s] %s::%s(%s)\n",
            remote.time,
            remote.name,
            remote.method,
            serializeArgs(remote.args)
        )
        if i >= 100 then
            exportText = exportText .. "... (limited to 100 entries)\n"
            break
        end
    end
    
    exportText = exportText .. "\n📝 LOGS (" .. #SpyTool.Data.logs .. " entries):\n"
    for i, log in ipairs(SpyTool.Data.logs) do
        exportText = exportText .. log .. "\n"
        if i >= 50 then
            exportText = exportText .. "... (limited to 50 entries)\n"
            break
        end
    end
    
    return exportText
end

-- Copiar para clipboard (iOS/Delta)
local function copyToClipboard(text)
    if setclipboard then
        setclipboard(text)
        return true
    elseif syn and syn.write_clipboard then
        syn.write_clipboard(text)
        return true
    elseif Clipboard and Clipboard.set then
        Clipboard.set(text)
        return true
    end
    return false
end

-- Inicializar
local function initialize()
    local ScreenGui, MainFrame, ContentFrame, TabsContainer, ExportBtn, MinimizeBtn, CloseBtn = createUI()
    
    -- Criar tabs
    local remotesTab = createTab(TabsContainer, "Remotes", 1)
    local logsTab = createTab(TabsContainer, "Logs", 2)
    local workspaceTab = createTab(TabsContainer, "Workspace", 3)
    
    local currentTab = "Remotes"
    
    -- Sistema de tabs
    local function switchTab(tabName, button)
        currentTab = tabName
        
        for _, child in ipairs(TabsContainer:GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
                child.TextColor3 = Color3.fromRGB(200, 200, 200)
            end
        end
        
        button.BackgroundColor3 = Color3.fromRGB(50, 150, 250)
        button.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        -- Limpar conteúdo
        for _, child in ipairs(ContentFrame:GetChildren()) do
            if not child:IsA("UIListLayout") then
                child:Destroy()
            end
        end
    end
    
    remotesTab.MouseButton1Click:Connect(function()
        switchTab("Remotes", remotesTab)
    end)
    
    logsTab.MouseButton1Click:Connect(function()
        switchTab("Logs", logsTab)
    end)
    
    workspaceTab.MouseButton1Click:Connect(function()
        switchTab("Workspace", workspaceTab)
        captureWorkspace()
    end)
    
    -- Atualizar conteúdo
    local lastUpdate = 0
    RunService.Heartbeat:Connect(function()
        if tick() - lastUpdate < Config.updateInterval then return end
        lastUpdate = tick()
        
        if currentTab == "Remotes" then
            -- Mostrar últimos 50 remotes
            local startIndex = math.max(1, #SpyTool.Data.remotes - 49)
            for i = startIndex, #SpyTool.Data.remotes do
                local remote = SpyTool.Data.remotes[i]
                local existing = ContentFrame:FindFirstChild("Remote_" .. i)
                if not existing then
                    local entry = createLogEntry(
                        ContentFrame,
                        string.format(
                            "[%s] %s::%s\nArgs: %s",
                            remote.time,
                            remote.name,
                            remote.method,
                            serializeArgs(remote.args)
                        )
                    )
                    entry.Name = "Remote_" .. i
                end
            end
        elseif currentTab == "Workspace" then
            local function displayTree(data, depth)
                local indent = string.rep("  ", depth)
                local text = string.format("%s[%s] %s", indent, data.class, data.name)
                createLogEntry(ContentFrame, text)
                
                for _, child in ipairs(data.children) do
                    displayTree(child, depth + 1)
                end
            end
            
            if SpyTool.Data.workspace.name then
                displayTree(SpyTool.Data.workspace, 0)
            end
        end
    end)
    
    -- Botão exportar
    ExportBtn.MouseButton1Click:Connect(function()
        local data = exportData()
        if copyToClipboard(data) then
            ExportBtn.Text = "✅ Copiado!"
            ExportBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
            task.wait(2)
            ExportBtn.Text = "📋 Exportar para Clipboard"
            ExportBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 250)
        else
            ExportBtn.Text = "❌ Erro ao copiar"
            ExportBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            task.wait(2)
            ExportBtn.Text = "📋 Exportar para Clipboard"
            ExportBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 250)
        end
    end)
    
    -- Minimizar
    local minimized = false
    MinimizeBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        MainFrame:TweenSize(
            minimized and UDim2.new(0, 350, 0, 45) or UDim2.new(0, 350, 0, 500),
            Enum.EasingDirection.Out,
            Enum.EasingStyle.Quad,
            0.3,
            true
        )
        MinimizeBtn.Text = minimized and "+" or "−"
    end)
    
    -- Fechar
    CloseBtn.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
        for remote, _ in pairs(SpyTool.Data.connections) do
            SpyTool.Data.connections[remote] = nil
        end
    end)
    
    -- Iniciar hooks
    hookRemotes()
    
    -- Tab inicial
    switchTab("Remotes", remotesTab)
    
    print("[Spy Tool] Inicializado com sucesso!")
end

-- Executar
initialize()
