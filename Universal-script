-- Misc Tab
local Tab4 = Window:NewTab("Misc")
local MiscSection = Tab4:NewSection("Miscellaneous")

MiscSection:NewButton("Reset Character", "Respawn your character", function()
    LocalPlayer.Character:BreakJoints()
end)

MiscSection:NewButton("Remove Script", "Unload the script", function()
    for _, connection in pairs(Connections) do
        connection:Disconnect()
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        RemoveESP(player)
    end
    
    if flyConnection then flyConnection:Disconnect() end
    if noclipConnection then noclipConnection:Disconnect() end
    
    game:GetService("CoreGui"):FindFirstChild("Kavo UI"):Destroy()
end)

-- Initialize ESP for existing players
for _, player in pairs(Players:GetPlayers()) do
    CreateESP(player)
end

-- Player connections
table.insert(Connections, Players.PlayerAdded:Connect(function(player)
    CreateESP(player)
end))

table.insert(Connections, Players.PlayerRemoving:Connect(function(player)
    RemoveESP(player)
end))

-- Character respawn handling
table.insert(Connections, LocalPlayer.CharacterAdded:Connect(function(character)
    wait(0.5)
    
    if Settings.Movement.Speed ~= 16 then
        character:WaitForChild("Humanoid").WalkSpeed = Settings.Movement.Speed
    end
    
    if Settings.Movement.JumpPower ~= 50 then
        character:WaitForChild("Humanoid").JumpPower = Settings.Movement.JumpPower
    end
    
    if Settings.Movement.Fly then
        ToggleFly(false)
        wait(0.5)
        ToggleFly(true)
    end
end))

-- Update ESP loop
table.insert(Connections, RunService.RenderStepped:Connect(function()
    for _, player in pairs(Players:GetPlayers()) do
        UpdateESP(player)
    end
end))

-- Infinite jump
table.insert(Connections, UserInputService.JumpRequest:Connect(function()
    if Settings.Combat.InfiniteJump and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end))

-- No fall damage
table.insert(Connections, RunService.Stepped:Connect(function()
    if Settings.Combat.NoFall and LocalPlayer.Character then
        local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
    end
end))

